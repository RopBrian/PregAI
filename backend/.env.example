# Example environment variables for the backend
# Replace placeholders before running locally or in CI.

# OpenRouter API key (or other LLM provider key)
OPENROUTER_API_KEY=REPLACE_ME_OPENROUTER_KEY

# Gemini / other model API key
GEMINI_API_KEY=REPLACE_ME_GEMINI_KEY

# Database connection (e.g. postgres://user:pass@host:port/dbname)
DATABASE_URL=REPLACE_ME_DATABASE_URL

# Django/Flask/Starlette secret key or app secret
SECRET_KEY=REPLACE_ME_SECRET_KEY

# Other recommended local settings
# DEBUG=True or False
DEBUG=True

# ML scan analysis is disabled by default for public/demo deployments.
# Set to true only when local model artifacts are available.
ENABLE_ML_ANALYSIS=false

# Prediction model set used by backend/chatbot/image_analyzer.py when ENABLE_ML_ANALYSIS=true.
# Supported values:
# v1 = module_a_3class_enhanced.pth + abnormal_classifier.pth
# v2 = module_a_3class_enhanced_v2.pth + abnormal_classifier_v2.pth
# v3/leakage_checked = module_a_3class_leakage_checked.pth + abnormal_classifier_leakage_checked.pth
ML_MODEL_VERSION=v3
